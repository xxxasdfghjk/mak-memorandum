---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('posts'))
  .sort((a, b) => {
    const aDate = a.data.date ? new Date(a.data.date).getTime() : 0;
    const bDate = b.data.date ? new Date(b.data.date).getTime() : 0;
    return bDate - aDate;
  });
---

<Layout title="memorandum" description="漫画・ゲーム・映画の感想のAI壁打ち記録を残すサイトです。">
  <main class="page">
    <section class="hero">
      <h1>感想・考察の記録</h1>
      <p>
        漫画・ゲーム・映画の感想のAI壁打ち記録を残すサイトです。
      </p>
      <a class="primary" href="/posts/danronv3">最新記事を見る</a>
    </section>

    <section class="posts">
      {posts.map((post) => (
        <article class="card">
          <p class="meta">
            {post.data.type ?? 'review'} • {post.data.date ? new Date(post.data.date).toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' }) : '未設定'}
          </p>
          <h2>
            <a href={`/posts/${post.id.replace(/\.md$/, '')}`}>{post.data.title}</a>
          </h2>
          <p>{post.body.slice(0, 140)}…</p>
          <div class="tags">
            {post.data.tags?.map((tag) => <span>{tag}</span>)}
          </div>
        </article>
      ))}
    </section>
  </main>
</Layout>
